# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host.neon.tech/xeron?sslmode=require"

# ── Authentication (REQUIRED) ───────────────────────────────────────────────
# Minimum 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=""

# 32 bytes / 64 hex chars. Generate with: openssl rand -hex 32
# Rotating this invalidates all previously encrypted at-rest secrets.
ENCRYPTION_KEY=""

# ── Google OAuth (REQUIRED for sign-in) ────────────────────────────────────
GOOGLE_CLIENT_ID=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# ── Cloudflare Turnstile (REQUIRED for sign-in) ────────────────────────────
TURNSTILE_SECRET_KEY=""
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

# ── Cron dispatcher (REQUIRED for scheduled tasks) ─────────────────────────
# Vercel Cron includes this as a Bearer token. Generate with: openssl rand -hex 32
CRON_SECRET=""

# ── AI providers ───────────────────────────────────────────────────────────
FOUR_EVER_LAND_API_KEY=""
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_AI_TOKEN=""

# ── Agent tools ────────────────────────────────────────────────────────────
# Serper powers the web_search tool the chat agent calls mid-conversation.
# Returns Google's actual SERP (organic results, answer box, knowledge
# graph, people-also-ask) as JSON.
# Free tier: 2,500 searches/month, no credit card required. https://serper.dev
# If unset, web_search returns a graceful error back to the model instead
# of crashing; the assistant will tell the user search is unavailable.
SERPER_API_KEY=""

# ── Integrations ───────────────────────────────────────────────────────────
COMPOSIO_API_KEY=""

# ── App URLs ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
