# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host.neon.tech/xeron?sslmode=require"

# ── Authentication (REQUIRED) ───────────────────────────────────────────────
# Minimum 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=""

# 32 bytes / 64 hex chars. Generate with: openssl rand -hex 32
# Rotating this invalidates all previously encrypted at-rest secrets.
ENCRYPTION_KEY=""

# ── Google OAuth (REQUIRED for sign-in) ────────────────────────────────────
GOOGLE_CLIENT_ID=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# ── Cloudflare Turnstile (REQUIRED for sign-in) ────────────────────────────
TURNSTILE_SECRET_KEY=""
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

# ── Cron dispatcher (REQUIRED for scheduled tasks) ─────────────────────────
# Vercel Cron includes this as a Bearer token. Generate with: openssl rand -hex 32
CRON_SECRET=""

# ── AI Providers ───────────────────────────────────────────────────────────

# Groq (free tier available, fast inference)
# Get your key at https://console.groq.com
GROQ_API_KEY=""

# OpenAI (GPT-4o, GPT-4o Mini)
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# Cloudflare Workers AI
# Get your account ID at https://dash.cloudflare.com
# Get your AI token at https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_AI_TOKEN=""

# HuggingFace Inference API
# Get your key at https://huggingface.co/settings/inference
HUGGINGFACE_API_KEY=""

# OpenRouter (unified API for 140+ models)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=""

# Jan.ai (local LLM via llama.cpp)
# Default URL: http://localhost:1337/v1/chat/completions
# No API key needed - runs locally
JAN_API_URL="http://localhost:1337/v1/chat/completions"

# ── Agent tools ────────────────────────────────────────────────────────────
# Serper powers the web_search tool the chat agent calls mid-conversation.
# Returns Google's actual SERP (organic results, answer box, knowledge
# graph, people-also-ask) as JSON.
# Free tier: 2,500 searches/month, no credit card required. https://serper.dev
# If unset, web_search returns a graceful error back to the model instead
# of crashing; the assistant will tell the user search is unavailable.
SERPER_API_KEY=""

# ── Integrations ──────────────────────────────────────────────────────────
COMPOSIO_API_KEY=""

# ── App URLs ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"